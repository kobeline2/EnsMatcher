# ============================================================
#  Mac + Python + MATLAB + Dropbox 併用環境 最適化 .gitignore
# ============================================================

# ---------------------------------------
# 1) Dropbox リンク（共有データ）
# ---------------------------------------
# Dropbox 側に置いたデータ置き場（シンボリックリンク）
# GitHub にデータを絶対に入れないため必須
data_shared/
deliverable/
out/
res/
config.yaml


# ---------------------------------------
# 2) Python バイトコード / キャッシュ
# ---------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.env/
*.egg-info/
.eggs/

# Jupyter notebooks cache
.ipynb_checkpoints/
.jupyter/

# ---------------------------------------
# 3) MATLAB 特有のゴミ / 中間生成物
# ---------------------------------------
*.mat
*.m~
*.asv       # autosave files
*.mex*      # compiled MEX files
slprj/      # Simulink build
sccprj/
codegen/

# MATLAB の補助ファイル
*.mlx.autosave
*.bak
*.log

# ---------------------------------------
# 4) 大容量データ（研究用中間生成物を誤コミットしない）
# ---------------------------------------
*.csv
*.h5
*.hdf5
*.nc
*.bin
*.dat
*.tif
*.tiff
*.jpg
*.png
*.mp4
*.mov

# ---------------------------------------
# 5) Mac 特有のゴミ
# ---------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# macOS が勝手に作るアイコンファイル（Icon\r → 文字化け対策）
Icon?
.icon?
._*

# ---------------------------------------
# 6) システム/エディタごとのファイル
# ---------------------------------------
# VSCode
.vscode/

# PyCharm / JetBrains
.idea/

# Backup files
*~

# ---------------------------------------
# 7) その他 sandbox / 作業用ディレクトリ
# ---------------------------------------
tmp/
temp/
scratch/
logs/
results/
figures/

# ---------------------------------------
# 8) 自分だけのローカル設定を置く場所
# ---------------------------------------
config_local/


# ---------------------------------------
# 9) C / C++ ビルド生成物・中間生成物
# ---------------------------------------
# コンパイル生成物
*.o
*.obj
*.lo
*.slo
*.so
*.dylib
*.dll
*.a
*.lib
*.la
*.exe
*.out
*.app

# 依存関係ファイル
*.d
*.dep

# デバッグ情報
*.pdb
*.dSYM/
*.su
*.gcda
*.gcno
*.gcov
*.profraw
*.profdata

# CMake
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
Makefile
compile_commands.json
*.cmake.user
**/cmake-build-*/

# Ninja
build.ninja
.ninja_deps
.ninja_log

# Autotools / libtool
autom4te.cache/
aclocal.m4
config.log
config.status
config.cache
configure
depcomp
install-sh
missing
m4/
libtool
ltmain.sh
*.in
*.m4

# Meson
meson-private/
meson-logs/
meson-info/

# その他よくあるビルドdir
build/
_build/
bin/
obj/

# ---------------------------------------
# specific for this project
# ---------------------------------------
parameters.m
config/
res/
old/
data/
test/
local/
preprocessed/
temp.m
src/cpp/materials/kaiseki_location.nc
src/python/venv